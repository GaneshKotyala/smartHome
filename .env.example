# ─── Application ─────────────────────────────────────────────────────────────

# Next.js frontend port
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ─── API (NestJS) ─────────────────────────────────────────────────────────────

# Server port
PORT=4000

# CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────

# SQLite file path (Phase 1 — relative to apps/api)
DATABASE_PATH=./data/ganesh-home-hub.sqlite

# PostgreSQL (Phase 2+ — uncomment and fill when migrating)
# DATABASE_URL=postgresql://user:password@localhost:5432/ganesh_home_hub

# ─── AI Integration (Phase 3) ─────────────────────────────────────────────────

# Gemini API key — get from https://aistudio.google.com
# GEMINI_API_KEY=your_key_here

# OpenAI API key (alternative)
# OPENAI_API_KEY=your_key_here

# ─── Security (Phase 2 — leave empty for Phase 1 local-only mode) ─────────────

# JWT secret for future auth
# JWT_SECRET=replace_with_a_strong_random_string
# JWT_EXPIRES_IN=7d

# ─── Feature Flags ────────────────────────────────────────────────────────────

# Toggle features without code changes
FEATURE_AI_ASSISTANT=false
FEATURE_CAMERA=false
FEATURE_MQTT=false
